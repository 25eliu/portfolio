# Portfolio Intelligence Platform — environment
# Copy to .env and fill in. PAPER KEYS ONLY. Never commit .env.

# Which market/broker adapter to use: "alpaca" (real paper account) or "fake" (offline/deterministic)
MARKET_ADAPTER=fake

# Alpaca paper-trading credentials (https://alpaca.markets -> Paper Trading -> generate keys)
ALPACA_KEY_ID=
ALPACA_SECRET=
ALPACA_PAPER=true
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Backend HTTP port
PORT=8787

# SQLite database file
DATABASE_PATH=./data/portfolio.sqlite
