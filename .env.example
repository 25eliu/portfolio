# Portfolio Intelligence Platform — environment
# Copy to .env and fill in. PAPER KEYS ONLY. Never commit .env.

# Which market/broker adapter to use: "alpaca" (real paper account) or "fake" (offline/deterministic)
MARKET_ADAPTER=fake

# Alpaca paper-trading credentials (https://alpaca.markets -> Paper Trading -> generate keys)
ALPACA_KEY_ID=
ALPACA_SECRET=
ALPACA_PAPER=true
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Backend HTTP port
PORT=8787

# SQLite database file
DATABASE_PATH=./data/portfolio.sqlite

# --- Phase 2: analysis ---
# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_LEVEL=medium
# Financial Modeling Prep free tier (https://site.financialmodelingprep.com/developer/docs)
FMP_API_KEY=
# FRED (https://fred.stlouisfed.org/docs/api/api_key.html — free)
FRED_API_KEY=
# Finnhub analyst consensus + earnings calendar (https://finnhub.io — free)
FINNHUB_API_KEY=
# Analysis tuning
LLM_CONCURRENCY=4
MAX_SCAN_CANDIDATES=8
# Max sentiment/thematic discovery candidates per run (0 disables the thematic pass)
MAX_THEMATIC_CANDIDATES=5
