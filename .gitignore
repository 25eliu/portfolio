# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Runtime & local data (SQLite + WAL/SHM). data/.gitkeep stays tracked.
data/*.sqlite
data/*.sqlite-*
data/*.db
/data.db
/data.db-*
# Raw uploaded/snapshotted knowledge-base files (metadata + extracted text live in SQLite).
data/knowledge/
data/*.db-*

# Environment & secrets (.env.example is committed as the template)
.env
.env.local
.env.*.local
.env.production

# Logs
*.log
logs/

# Test artifacts
test-results/
playwright-report/
playwright/.cache/
coverage/

# Project documentation: keep the canonical architecture tracked, but leave working notes private.
docs/*
!docs/architecture-and-roadmap.md
!docs/integrations-roadmap.md
docs/local/
docs/conversations/
docs/plans/

# Personal notes, wiki, stock-data dumps — NOT part of the template.
# Root-anchored so these never shadow source dirs (e.g. src/wiki/ is tracked code).
/wiki/
/notes/
/scratch/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Agent / tooling workspace caches
.gstack/
.claude/
.superpowers/
.sageox/kb/
